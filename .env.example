# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
# Spring Boot loads this automatically via spring.config.import in application.yml.

# KIS Developers (한국투자증권 오픈API)
# Get keys at: https://apiportal.koreainvestment.com/
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=12345678-01
KIS_PAPER_TRADING=true

# DART OpenAPI (금융감독원 전자공시)
# Get key at: https://opendart.fss.or.kr/
DART_API_KEY=

# OpenAI (GPT) — for 공시 sentiment analysis
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

LOG_LEVEL=INFO
